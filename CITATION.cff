    given-names: Anand
version: 0.1.0
date-released: 2026-06-10
license: MIT
keywords:
  - molecular dynamics
  - trajectory compression
  - Markov state model
  - normalizing flow
  - kinetics
  - Pinsker bound
repository-code: "https://github.com/anandojha/epc"
url: "https://github.com/anandojha/epc"
